{
  "name": "douyinlm-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests && node --test scripts/audit-evaluation.node-test.mjs",
    "audit:release": "node scripts/audit-release.mjs",
    "audit:evaluation": "node scripts/audit-evaluation.mjs",
    "verify:release": "npm run test && npm run build && npm run audit:release"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
